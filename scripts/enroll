#!/usr/bin/env bash
# enroll — Register this host + GitHub user with the openclaw-team repo.
#
# Usage:
#   ./scripts/enroll <github-username> [key-label]
#
# What it does:
#   1. Reads the host's age public key (from sops-nix or ssh host key)
#   2. Fetches SSH keys from github.com/<username>.keys
#   3. Converts ed25519 SSH keys to age public keys
#   4. Writes keys to keys/<label>.txt
#   5. Regenerates .sops.yaml with all keys from keys/
#   6. Commits and pushes → GitHub Actions re-encrypts secrets
#
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
KEYS_DIR="${REPO_ROOT}/keys"
SOPS_YAML="${REPO_ROOT}/.sops.yaml"

# --- Helpers ---

die() { echo "Error: $*" >&2; exit 1; }

need() {
  command -v "$1" >/dev/null 2>&1 || die "'$1' not found. Install it first."
}

get_host_age_key() {
  # Try sops-nix generated key first
  local sops_key="${HOME}/.config/sops/age/keys.txt"
  if [[ -f "$sops_key" ]]; then
    age-keygen -y "$sops_key" 2>/dev/null && return
  fi

  # Fall back to SSH host key
  for key_file in /etc/ssh/ssh_host_ed25519_key.pub "${HOME}/.ssh/id_ed25519.pub"; do
    if [[ -f "$key_file" ]]; then
      ssh-to-age -i "$key_file" 2>/dev/null && return
    fi
  done

  die "No age key found. Ensure sops-nix is configured or an ed25519 SSH key exists."
}

fetch_github_age_keys() {
  local username="$1"
  local url="https://github.com/${username}.keys"
  local keys_raw

  keys_raw="$(curl -sf "$url" 2>/dev/null)" || {
    echo "Warning: Could not fetch keys from ${url}" >&2
    return
  }

  # Convert each ed25519 key to age
  while IFS= read -r line; do
    if [[ "$line" == ssh-ed25519* ]]; then
      echo "$line" | ssh-to-age 2>/dev/null || true
    fi
  done <<< "$keys_raw"
}

regenerate_sops_yaml() {
  # Static keys that are always included
  local -a static_keys=(
    "age1psa52j93p0t7rej4lyzeww6hzg9hh4ylxu6v30tcgag44apw8als2xg3ef"   # cooper
    "age1tppj4vwjyt24xulxr7ecmqlwd2q7wjzrdxgm5zqreayyw69rdaes542hjr"   # github_actions
  )

  # Collect all keys from keys/ directory
  local -a member_keys=()
  for keyfile in "${KEYS_DIR}"/*.txt; do
    [[ -f "$keyfile" ]] || continue
    while IFS= read -r key; do
      key="$(echo "$key" | sed 's/#.*//' | xargs)"  # strip comments + whitespace
      [[ -n "$key" ]] && member_keys+=("$key")
    done < "$keyfile"
  done

  # Build .sops.yaml
  cat > "$SOPS_YAML" <<'HEADER'
# Auto-generated by scripts/enroll — do not edit manually.
# To add a team member: ./scripts/enroll <github-username>
# Keys are stored in keys/<label>.txt

keys:
  # --- Core (always present) ---
  - &cooper age1psa52j93p0t7rej4lyzeww6hzg9hh4ylxu6v30tcgag44apw8als2xg3ef
  - &github_actions age1tppj4vwjyt24xulxr7ecmqlwd2q7wjzrdxgm5zqreayyw69rdaes542hjr

  # --- Team Members (from keys/ directory) ---
HEADER

  local idx=0
  for keyfile in "${KEYS_DIR}"/*.txt; do
    [[ -f "$keyfile" ]] || continue
    local label
    label="$(basename "$keyfile" .txt)"
    while IFS= read -r key; do
      key="$(echo "$key" | sed 's/#.*//' | xargs)"
      [[ -n "$key" ]] || continue
      echo "  - &${label}_${idx} ${key}" >> "$SOPS_YAML"
      ((idx++))
    done < "$keyfile"
  done

  # Creation rules — include all keys
  cat >> "$SOPS_YAML" <<'RULES_HEADER'

creation_rules:
  - path_regex: secrets/.*\.yaml$
    age:
      - *cooper
      - *github_actions
RULES_HEADER

  idx=0
  for keyfile in "${KEYS_DIR}"/*.txt; do
    [[ -f "$keyfile" ]] || continue
    local label
    label="$(basename "$keyfile" .txt)"
    while IFS= read -r key; do
      key="$(echo "$key" | sed 's/#.*//' | xargs)"
      [[ -n "$key" ]] || continue
      echo "      - *${label}_${idx}" >> "$SOPS_YAML"
      ((idx++))
    done < "$keyfile"
  done
}

# --- Main ---

need curl
need age-keygen
need ssh-to-age
need git

GITHUB_USER="${1:-}"
[[ -n "$GITHUB_USER" ]] || die "Usage: $0 <github-username> [key-label]"

KEY_LABEL="${2:-${GITHUB_USER}}"

echo "=== OpenClaw Team Enrollment ==="
echo "GitHub user:  ${GITHUB_USER}"
echo "Key label:    ${KEY_LABEL}"
echo ""

mkdir -p "$KEYS_DIR"

KEYFILE="${KEYS_DIR}/${KEY_LABEL}.txt"

# Collect keys
{
  echo "# ${KEY_LABEL} — enrolled $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "# GitHub: ${GITHUB_USER}"
  echo ""

  echo "# Host age key"
  HOST_KEY="$(get_host_age_key)"
  if [[ -n "$HOST_KEY" ]]; then
    echo "$HOST_KEY"
    echo "  → Host key: ${HOST_KEY}"
  fi

  echo ""
  echo "# From github.com/${GITHUB_USER}.keys"
  GH_KEYS="$(fetch_github_age_keys "$GITHUB_USER")"
  if [[ -n "$GH_KEYS" ]]; then
    echo "$GH_KEYS"
    while IFS= read -r k; do
      echo "  → GitHub key: ${k}"
    done <<< "$GH_KEYS"
  fi
} > "$KEYFILE" 2>&1

# Show what we collected (filter out the echo lines that went to the file)
echo ""
echo "Keys written to: ${KEYFILE}"
grep "^age1" "$KEYFILE" | while read -r k; do
  echo "  ${k}"
done
echo ""

# Regenerate .sops.yaml
echo "Regenerating .sops.yaml..."
regenerate_sops_yaml
echo "Done."
echo ""

# Commit and push
cd "$REPO_ROOT"
git add "keys/${KEY_LABEL}.txt" .sops.yaml
if git diff --cached --quiet; then
  echo "No changes to commit."
else
  git commit -m "enroll: add ${KEY_LABEL} (${GITHUB_USER})"
  echo ""
  echo "Pushing to trigger GitHub Actions re-encryption..."
  git push
  echo ""
  echo "✓ Enrolled! GitHub Actions will re-encrypt secrets with the new key."
  echo "  The member can now decrypt secrets with their age key."
fi
