#!/usr/bin/env bash
# enroll — Register this host + GitHub user with the openclaw-team repo.
#
# Usage:
#   ./scripts/enroll <github-username> [key-label]
#
# What it does:
#   1. Gets the host's age public key:
#      a. From /etc/ssh/ssh_host_ed25519_key.pub (if available)
#      b. Otherwise auto-generates into ~/Library/Application Support/sops/age/keys.txt
#         (the default sops location on macOS)
#   2. Fetches SSH keys from github.com/<username>.keys
#   3. Converts ed25519 SSH keys to age public keys
#   4. Writes keys to keys/<label>.txt
#   5. Regenerates .sops.yaml with all keys from keys/
#   6. Commits and pushes → GitHub Actions re-encrypts secrets
#
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
KEYS_DIR="${REPO_ROOT}/keys"
SOPS_YAML="${REPO_ROOT}/.sops.yaml"

# sops default key paths (checked in order)
if [[ "$(uname)" == "Darwin" ]]; then
  SOPS_AGE_DIR="${HOME}/Library/Application Support/sops/age"
else
  SOPS_AGE_DIR="${HOME}/.config/sops/age"
fi
SOPS_AGE_KEYFILE="${SOPS_AGE_DIR}/keys.txt"

# --- Helpers ---

die() { echo "Error: $*" >&2; exit 1; }

need() {
  command -v "$1" >/dev/null 2>&1 || die "'$1' not found. Install it first."
}

get_host_age_key() {
  # 1. Try SSH host key (works on macOS + Linux, no user interaction)
  local ssh_host_pub="/etc/ssh/ssh_host_ed25519_key.pub"
  if [[ -f "$ssh_host_pub" ]]; then
    local age_key
    age_key="$(ssh-to-age -i "$ssh_host_pub" 2>/dev/null)" || true
    if [[ -n "$age_key" ]]; then
      echo "$age_key"
      echo "  → Source: ${ssh_host_pub}" >&2
      return
    fi
  fi

  # 2. Check if sops age key already exists
  if [[ -f "$SOPS_AGE_KEYFILE" ]]; then
    local pub
    pub="$(age-keygen -y "$SOPS_AGE_KEYFILE" 2>/dev/null)" || true
    if [[ -n "$pub" ]]; then
      echo "$pub"
      echo "  → Source: ${SOPS_AGE_KEYFILE} (existing)" >&2
      return
    fi
  fi

  # 3. Auto-generate age key into sops default location
  echo "  → No SSH host key or existing age key found." >&2
  echo "  → Generating new age key at: ${SOPS_AGE_KEYFILE}" >&2
  mkdir -p "$SOPS_AGE_DIR"
  age-keygen -o "$SOPS_AGE_KEYFILE" 2>/dev/null
  chmod 600 "$SOPS_AGE_KEYFILE"
  age-keygen -y "$SOPS_AGE_KEYFILE"
}

fetch_github_age_keys() {
  local username="$1"
  local url="https://github.com/${username}.keys"
  local keys_raw

  keys_raw="$(curl -sf "$url" 2>/dev/null)" || {
    echo "  → Warning: Could not fetch keys from ${url}" >&2
    return
  }

  while IFS= read -r line; do
    if [[ "$line" == ssh-ed25519* ]]; then
      local converted
      converted="$(echo "$line" | ssh-to-age 2>/dev/null)" || true
      if [[ -n "$converted" ]]; then
        echo "$converted"
      fi
    fi
  done <<< "$keys_raw"
}

regenerate_sops_yaml() {
  # Static keys that are always included
  cat > "$SOPS_YAML" <<'HEADER'
# Auto-generated by scripts/enroll — do not edit manually.
# To add a team member: ./scripts/enroll <github-username>
# Keys are stored in keys/<label>.txt

keys:
  # --- Core (always present) ---
  - &cooper age1psa52j93p0t7rej4lyzeww6hzg9hh4ylxu6v30tcgag44apw8als2xg3ef
  - &github_actions age1tppj4vwjyt24xulxr7ecmqlwd2q7wjzrdxgm5zqreayyw69rdaes542hjr

  # --- Team Members (from keys/ directory) ---
HEADER

  local idx=0
  for keyfile in "${KEYS_DIR}"/*.txt; do
    [[ -f "$keyfile" ]] || continue
    local label
    label="$(basename "$keyfile" .txt)"
    while IFS= read -r key; do
      key="$(echo "$key" | sed 's/#.*//' | xargs)"
      [[ -n "$key" ]] || continue
      echo "  - &${label}_${idx} ${key}" >> "$SOPS_YAML"
      ((idx++))
    done < "$keyfile"
  done

  cat >> "$SOPS_YAML" <<'RULES_HEADER'

creation_rules:
  - path_regex: secrets/.*\.yaml$
    age:
      - *cooper
      - *github_actions
RULES_HEADER

  idx=0
  for keyfile in "${KEYS_DIR}"/*.txt; do
    [[ -f "$keyfile" ]] || continue
    local label
    label="$(basename "$keyfile" .txt)"
    while IFS= read -r key; do
      key="$(echo "$key" | sed 's/#.*//' | xargs)"
      [[ -n "$key" ]] || continue
      echo "      - *${label}_${idx}" >> "$SOPS_YAML"
      ((idx++))
    done < "$keyfile"
  done
}

# --- Main ---

need curl
need age-keygen
need ssh-to-age
need git

GITHUB_USER="${1:-}"
[[ -n "$GITHUB_USER" ]] || die "Usage: $0 <github-username> [key-label]"

KEY_LABEL="${2:-${GITHUB_USER}}"

echo "=== OpenClaw Team Enrollment ==="
echo "GitHub user:  ${GITHUB_USER}"
echo "Key label:    ${KEY_LABEL}"
echo ""

mkdir -p "$KEYS_DIR"

KEYFILE="${KEYS_DIR}/${KEY_LABEL}.txt"

# Collect keys into temp, then write
TMPFILE="$(mktemp)"
trap 'rm -f "$TMPFILE"' EXIT

{
  echo "# ${KEY_LABEL} — enrolled $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "# GitHub: ${GITHUB_USER}"
  echo ""
} > "$TMPFILE"

echo "Resolving host age key..."
HOST_KEY="$(get_host_age_key)"
if [[ -n "$HOST_KEY" ]]; then
  echo "# Host age key" >> "$TMPFILE"
  echo "$HOST_KEY" >> "$TMPFILE"
  echo "  ✓ Host key: ${HOST_KEY}"
fi

echo ""
echo "Fetching github.com/${GITHUB_USER}.keys..."
GH_KEYS="$(fetch_github_age_keys "$GITHUB_USER")"
if [[ -n "$GH_KEYS" ]]; then
  {
    echo ""
    echo "# From github.com/${GITHUB_USER}.keys"
    echo "$GH_KEYS"
  } >> "$TMPFILE"
  while IFS= read -r k; do
    echo "  ✓ GitHub key: ${k}"
  done <<< "$GH_KEYS"
else
  echo "  (no ed25519 keys found on GitHub)"
fi

cp "$TMPFILE" "$KEYFILE"
echo ""
echo "Keys written to: ${KEYFILE}"
echo ""

# Regenerate .sops.yaml
echo "Regenerating .sops.yaml..."
regenerate_sops_yaml
echo "Done."
echo ""

# Commit and push
cd "$REPO_ROOT"
git add "keys/${KEY_LABEL}.txt" .sops.yaml
if git diff --cached --quiet; then
  echo "No changes to commit."
else
  git commit -m "enroll: add ${KEY_LABEL} (${GITHUB_USER})"
  echo ""
  echo "Pushing to trigger GitHub Actions re-encryption..."
  git push
  echo ""
  echo "✓ Enrolled! GitHub Actions will re-encrypt secrets with the new key."
  echo "  The member can now decrypt secrets with their age key."
fi
